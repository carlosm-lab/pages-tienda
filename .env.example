# ========================
# Frontend (Vite) Variables
# ========================
# URL de API de tu proyecto Supabase (encontrada en Settings > API)
VITE_SUPABASE_URL=tu_url_de_supabase
# Clave anónima pública de Supabase
VITE_SUPABASE_ANON_KEY=tu_clave_anon_de_supabase

# Información de Contacto Pública
VITE_WHATSAPP_NUMBER=50312345678
VITE_CONTACT_EMAIL=info@tu-dominio.com

# Cloudflare Turnstile (Protección contra bots)
# Site Key Pública para el frontend
VITE_TURNSTILE_SITE_KEY=tu_site_key_de_cloudflare_turnstile

# ========================
# Edge Function Secrets (Back-end)
# Nota: Estas no van en .env local para Vite, se configuran vía:
# npx supabase secrets set TURNSTILE_SECRET_KEY=xxx
# O en el Dashboard: Project Settings > Edge Functions > Secrets
# ========================
# Secret Key privada de Cloudflare Turnstile
# TURNSTILE_SECRET_KEY=tu_secret_key_de_cloudflare_turnstile
# Origen permitido para CORS (asegura el endpoint)
# ALLOWED_ORIGIN=https://tu-dominio.com

